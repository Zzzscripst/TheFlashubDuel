local function createBtn(name, color, callback)
    local btn = sidePanel:FindFirstChild(name) or Instance.new("TextButton", sidePanel); btn.Name = name
    btn.Size = UDim2.new(0, 80, 0, 80); btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20); btn.Text = name; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.GothamBold; btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 12); local stroke = btn:FindFirstChild("UIStroke") or Instance.new("UIStroke", btn); stroke.Color = color; stroke.Thickness = 3
    btn.MouseButton1Click:Connect(function()
        if name == "DROP" then callback()
        else
            if name == "AutoLeft" then AutoLeft = not AutoLeft; AutoRight = false; if AutoLeft then runMove(P_L) end
            else AutoRight = not AutoRight; AutoLeft = false; if AutoRight then runMove(P_R) end end
            stroke.Color = (AutoLeft or AutoRight) and Color3.new(1,1,1) or color
        end
    end)
end

createBtn("AutoLeft", Color3.fromRGB(0, 0, 255), nil)
createBtn("AutoRight", Color3.fromRGB(255, 0, 0), nil)
createBtn("DROP", Color3.fromRGB(255, 255, 0), DropBrainrot)

