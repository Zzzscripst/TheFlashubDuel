-- 6. DROP BRAINROT
local function DropBrainrot()
    local char = LocalPlayer.Character; local hrp = char and char:FindFirstChild("HumanoidRootPart"); local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    local groundPos = hrp.Position
    hum:ChangeState(Enum.HumanoidStateType.Jumping)
    hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 140, hrp.AssemblyLinearVelocity.Z)
    task.wait(0.2)
    hrp.CFrame = CFrame.new(groundPos); hrp.AssemblyLinearVelocity = Vector3.zero
end

-- 7. AUTO MOVIMENTO (LÓGICA DOS 3 PONTOS COM 2S DE ESPERA)
local P_L = {Vector3.new(-476.48,-6.28,92.73), Vector3.new(-483.12,-4.95,94.80), Vector3.new(-473.38,-8.40,22.34)}
local P_R = {Vector3.new(-476.16,-6.52,25.62), Vector3.new(-483.04,-5.09,23.14), Vector3.new(-476.17,-7.91,97.91)}

local AutoLeft, AutoRight = false, false
local function runMove(points)
    task.spawn(function()
        local phase = 1
        while (AutoLeft or AutoRight) do
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.RootPart then
                hum:MoveTo(points[phase])
                if (hum.RootPart.Position - points[phase]).Magnitude < 4 then
                    phase = (phase % #points) + 1
                    task.wait(2) -- Tempo de espera solicitado
                end
            end
            task.wait(0.1)
        end
    end)
end

